# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
DATABASE_URL=sqlite+aiosqlite:///./backend/data/complaints.db

# Auth
JWT_SECRET=please-change-to-a-secure-random-string
JWT_EXPIRY_DAYS=7
AUTH_MODE=local

# IAM (when AUTH_MODE=iam)
IAM_ISSUER=https://iam.internal.company.com
IAM_CLIENT_ID=report-agent-platform
IAM_CLIENT_SECRET=xxx
IAM_REDIRECT_URI=http://platform.internal/api/auth/iam/callback

# LLM (支持 claude / openai / deepseek)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_API_KEY=

# OpenAI-compatible (vLLM/Ollama 本地模型)
LLM_OPENAI_BASE_URL=http://localhost:8080/v1
LLM_OPENAI_MODEL=qwen2.5-7b-instruct
LLM_OPENAI_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Data Source
COMPLAINT_EXCEL_PATH=
